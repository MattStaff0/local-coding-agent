# Copy to .env and edit. Loaded automatically on startup; a variable already
# exported in your shell always wins over this file.

# --- Connection ---
# Where Ollama actually runs (the Windows PC on the LAN, not this machine).
OLLAMA_HOST=http://192.168.1.50:11434

# --- Models ---
# Any chat model your Ollama has pulled. The agent loop needs one with tool
# support (`ollama show <model>` lists "tools" under capabilities).
OLLAMA_CHAT_MODEL=qwen2.5-coder:3b
# Changing the embed model requires re-running src/ingest.py (chunks are
# fingerprinted per-model, so everything re-embeds automatically).
OLLAMA_EMBED_MODEL=nomic-embed-text

# --- Retrieval knobs (defaults shown; uncomment to change) ---
# RAG_RELEVANCE_CUTOFF=0.65
# RAG_PROMPT_BUDGET=12000
# RAG_RERANKER=cross-encoder
# RAG_RERANK_MODEL=cross-encoder/ms-marco-MiniLM-L6-v2

# --- Paths (rarely needed) ---
# LCA_HOME=/path/to/index/anchor
# RAG_MANIFEST_PATH=
# RAG_CODE_MANIFEST_PATH=
# STUDY_NOTES_DIR=
